{
  "name": "vytalguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "nodemon backend/src/server.js",
    "start": "cross-env NODE_ENV=production node backend/src/server.js",
    "migrate": "sequelize db:migrate --migrations-path backend/src/db/migrations --config backend/config/config.cjs",
    "migrate:status": "sequelize db:migrate:status --migrations-path backend/src/db/migrations --config backend/config/config.cjs",
    "migrate:undo": "sequelize db:migrate:undo --migrations-path backend/src/db/migrations --config backend/config/config.cjs",
    "seed": "sequelize db:seed:all --seeders-path backend/src/db/seeders --config backend/config/config.cjs",
    "seed:undo": "sequelize db:seed:undo:all --seeders-path backend/src/db/seeders --config backend/config/config.cjs",
    "lb:up": "docker compose -f infra/docker/docker-compose.lb.yml up -d --build",
    "lb:down": "docker compose -f infra/docker/docker-compose.lb.yml down -v"
  },
  "dependencies": {
    "apexcharts": "^5.3.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "joi": "^18.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "selfsigned": "^3.0.1",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.3"
  }
}
